# Defina o token real somente no ambiente de runtime do Coolify.
TELEGRAM_BOT_TOKEN=coloque_o_novo_token_no_coolify

DATA_DIR=/app/data
DEFAULT_MODEL=gpt-5.4-mini
IMAGE_MODEL=gpt-image-2
MAX_IMAGES=5
LOG_LEVEL=INFO

# Recomendado: IDs numéricos separados por vírgula. Vazio permite qualquer usuário.
ALLOWED_TELEGRAM_USER_IDS=
